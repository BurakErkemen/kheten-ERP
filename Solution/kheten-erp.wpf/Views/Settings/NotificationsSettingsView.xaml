<UserControl x:Class="kheten_erp.wpf.Views.Settings.NotificationsSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
        <StackPanel MaxWidth="720" HorizontalAlignment="Left">

            <TextBlock Text="Bildirimler" Style="{StaticResource H1}"/>
            <TextBlock Text="Hangi olaylarda uyarı almak istediğinizi seçin" Style="{StaticResource Muted}" Margin="0,3,0,20"/>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <!-- Satır 1 -->
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Kritik stok uyarısı" FontWeight="SemiBold" Foreground="{DynamicResource Fg}" FontSize="13.5"/>
                            <TextBlock Text="Ürün minimum stok seviyesinin altına düştüğünde bildir" Style="{StaticResource Muted}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="True" HorizontalAlignment="Right"/>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource Border}" Margin="0,16"/>
                    <!-- Satır 2 -->
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Yeni sipariş bildirimi" FontWeight="SemiBold" Foreground="{DynamicResource Fg}" FontSize="13.5"/>
                            <TextBlock Text="Pazaryerlerinden yeni sipariş geldiğinde bildir" Style="{StaticResource Muted}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="True" HorizontalAlignment="Right"/>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource Border}" Margin="0,16"/>
                    <!-- Satır 3 -->
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Geciken tahsilat hatırlatması" FontWeight="SemiBold" Foreground="{DynamicResource Fg}" FontSize="13.5"/>
                            <TextBlock Text="Vadesi geçen fatura olduğunda bildir" Style="{StaticResource Muted}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource Border}" Margin="0,16"/>
                    <!-- Satır 4 -->
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="E-posta özeti" FontWeight="SemiBold" Foreground="{DynamicResource Fg}" FontSize="13.5"/>
                            <TextBlock Text="Günlük işletme özetini e-posta ile gönder" Style="{StaticResource Muted}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
