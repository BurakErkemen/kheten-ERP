<Window x:Class="kheten_erp.wpf.Views.PurchaseEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="Satınalma Siparişi" Width="460" SizeToContent="Height"
        ResizeMode="NoResize" WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Surface}">
    <Grid Margin="24,20,24,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <StackPanel>
                <TextBlock x:Name="HeaderTitle" Text="Yeni Satınalma Siparişi" Style="{StaticResource H1}" FontSize="19"/>
                <TextBlock Text="Sipariş başlık bilgileri" Style="{StaticResource Muted}" Margin="0,2,0,0"/>
            </StackPanel>
            <Button Style="{StaticResource GridIconButton}" HorizontalAlignment="Right" VerticalAlignment="Top" Click="Cancel_Click">
                <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource FgMuted}" Data="{StaticResource Icon.Close}"/>
            </Button>
        </Grid>

        <StackPanel Grid.Row="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Belge No" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource InputBox}" Text="{Binding No, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Tarih" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource InputBox}" Text="{Binding Date, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Tedarikçi" Style="{StaticResource FieldLabel}" Margin="0,14,0,6"/>
            <TextBox Style="{StaticResource InputBox}" Text="{Binding Supplier, UpdateSourceTrigger=PropertyChanged}"/>

            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Tutar" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource InputBox}" Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Durum" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource Combo}" SelectedItem="{Binding Status, Mode=TwoWay}">
                        <sys:String>Sipariş Verildi</sys:String>
                        <sys:String>Teslim Bekliyor</sys:String>
                        <sys:String>Onaylandı</sys:String>
                        <sys:String>İptal</sys:String>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="İptal" Width="100" Click="Cancel_Click"/>
            <Button Style="{StaticResource PrimaryButton}" Content="Kaydet" Width="120" Margin="10,0,0,0" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
