<UserControl x:Class="kheten_erp.wpf.Views.ContactsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             Background="{DynamicResource AppBg}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Cari Hesaplar" Style="{StaticResource H1}"/>
                <TextBlock Text="Müşteri ve tedarikçi kartları, bakiye takibi" Style="{StaticResource Muted}" Margin="0,3,0,0"/>
            </StackPanel>
            <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" VerticalAlignment="Top" Click="AddContact_Click">
                <StackPanel Orientation="Horizontal">
                    <Path Width="15" Height="15" Stretch="Uniform" Fill="White" Data="{StaticResource Icon.Add}" VerticalAlignment="Center"/>
                    <TextBlock Text="Yeni Cari" Margin="7,0,0,0" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Araç çubuğu -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Border Width="300" Height="38" CornerRadius="8" Background="{DynamicResource Surface}"
                        BorderBrush="{DynamicResource Border}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Width="16" Height="16" Margin="11,0,0,0" Stretch="Uniform" VerticalAlignment="Center"
                              Fill="{DynamicResource FgMuted}" Data="{StaticResource Icon.Search}"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="SearchBox" BorderThickness="0" Background="Transparent"
                                     Foreground="{DynamicResource Fg}" CaretBrush="{DynamicResource Fg}"
                                     FontSize="13" VerticalContentAlignment="Center" Margin="6,0,8,0"
                                     TextChanged="Filter_Changed"/>
                            <TextBlock Text="Cari adı veya kodu ara" IsHitTestVisible="False"
                                       Foreground="{DynamicResource FgMuted}" FontSize="13"
                                       VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <ComboBox x:Name="TypeFilter" Style="{StaticResource Combo}" Width="180" Margin="10,0,0,0"
                          SelectedIndex="0" SelectionChanged="Filter_Changed">
                    <sys:String>Tip: Tümü</sys:String>
                    <sys:String>Müşteri</sys:String>
                    <sys:String>Tedarikçi</sys:String>
                </ComboBox>

                <TextBlock x:Name="ResultCount" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="14,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Tablo -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="Grid" Style="{StaticResource DataGridStyle}"
                      ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}"
                      CellStyle="{StaticResource CellStyle}" RowStyle="{StaticResource RowStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="KOD" Binding="{Binding Code}" Width="100"/>
                    <DataGridTextColumn Header="ÜNVAN" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="TİP" Binding="{Binding Type}" Width="120"/>
                    <DataGridTextColumn Header="TELEFON" Binding="{Binding Phone}" Width="160"/>
                    <DataGridTemplateColumn Header="BAKİYE" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Balance}" FontWeight="SemiBold" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding BalanceKind}" Value="warn">
                                                    <Setter Property="Foreground" Value="{DynamicResource Warning}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding BalanceKind}" Value="err">
                                                    <Setter Property="Foreground" Value="{DynamicResource Danger}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="İŞLEMLER" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource GridIconButton}" Click="EditContact_Click" ToolTip="Düzenle">
                                        <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource FgMuted}" Data="{StaticResource Icon.Edit}"/>
                                    </Button>
                                    <Button Style="{StaticResource GridIconButton}" Click="DeleteContact_Click" ToolTip="Sil" Margin="2,0,0,0">
                                        <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource Danger}" Data="{StaticResource Icon.Delete}"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
