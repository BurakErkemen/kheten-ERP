<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== AÇIK TEMA (LIGHT) =====
         Tüm renkler bu anahtarlarla tanımlıdır. Koyu tema aynı anahtarları
         kullanır; ThemeManager bu sözlüğü değiştirerek temayı çevirir.
         Kontroller bu fırçalara DynamicResource ile bağlanır. -->

    <!-- Zemin / yüzeyler -->
    <SolidColorBrush x:Key="AppBg"          Color="#F1F5F9"/>
    <SolidColorBrush x:Key="Surface"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceAlt"     Color="#F8FAFC"/>
    <SolidColorBrush x:Key="Topbar"         Color="#FFFFFF"/>

    <!-- Sol menü -->
    <SolidColorBrush x:Key="Sidebar"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarBorder"  Color="#E2E8F0"/>
    <SolidColorBrush x:Key="NavText"        Color="#475569"/>
    <SolidColorBrush x:Key="NavTextActive"  Color="#2563EB"/>
    <SolidColorBrush x:Key="NavActiveBg"    Color="#EFF6FF"/>
    <SolidColorBrush x:Key="NavHoverBg"     Color="#F1F5F9"/>

    <!-- Vurgu / birincil -->
    <SolidColorBrush x:Key="Primary"        Color="#2563EB"/>
    <SolidColorBrush x:Key="PrimaryHover"   Color="#1D4ED8"/>
    <SolidColorBrush x:Key="OnPrimary"      Color="#FFFFFF"/>

    <!-- Metin -->
    <SolidColorBrush x:Key="Fg"             Color="#0F172A"/>
    <SolidColorBrush x:Key="FgMuted"        Color="#64748B"/>

    <!-- Kenarlık -->
    <SolidColorBrush x:Key="Border"         Color="#E2E8F0"/>

    <!-- Durum renkleri -->
    <SolidColorBrush x:Key="Success"        Color="#15803D"/>
    <SolidColorBrush x:Key="SuccessBg"      Color="#DCFCE7"/>
    <SolidColorBrush x:Key="Warning"        Color="#B45309"/>
    <SolidColorBrush x:Key="WarningBg"      Color="#FEF3C7"/>
    <SolidColorBrush x:Key="Danger"         Color="#B91C1C"/>
    <SolidColorBrush x:Key="DangerBg"       Color="#FEE2E2"/>
    <SolidColorBrush x:Key="Info"           Color="#0369A1"/>
    <SolidColorBrush x:Key="InfoBg"         Color="#E0F2FE"/>

    <!-- Grafik serileri -->
    <SolidColorBrush x:Key="Chart1"         Color="#2563EB"/>
    <SolidColorBrush x:Key="Chart2"         Color="#0EA5E9"/>
    <SolidColorBrush x:Key="ChartTrack"     Color="#E2E8F0"/>

</ResourceDictionary>
