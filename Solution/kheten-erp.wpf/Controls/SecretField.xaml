<UserControl x:Class="kheten_erp.wpf.Controls.SecretField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <StackPanel>
        <TextBlock x:Name="LabelText" Style="{StaticResource FieldLabel}"/>
        <Border Height="38" CornerRadius="8" Background="{DynamicResource Surface}"
                BorderBrush="{DynamicResource Border}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Maskeli giriş -->
                <PasswordBox x:Name="Pwd" Grid.Column="0" BorderThickness="0" Background="Transparent"
                             Foreground="{DynamicResource Fg}" CaretBrush="{DynamicResource Fg}"
                             FontSize="13" VerticalContentAlignment="Center" Margin="11,0,0,0"/>
                <!-- Açık giriş (göster modunda) -->
                <TextBox x:Name="Txt" Grid.Column="0" BorderThickness="0" Background="Transparent"
                         Foreground="{DynamicResource Fg}" CaretBrush="{DynamicResource Fg}"
                         FontSize="13" VerticalContentAlignment="Center" Margin="11,0,0,0"
                         Visibility="Collapsed"/>

                <!-- Göster/Gizle -->
                <Button x:Name="RevealBtn" Grid.Column="1" Style="{StaticResource GridIconButton}"
                        Margin="0,0,3,0" Click="Reveal_Click" ToolTip="Göster / Gizle">
                    <Path x:Name="RevealIcon" Width="17" Height="17" Stretch="Uniform"
                          Fill="{DynamicResource FgMuted}" Data="{StaticResource Icon.Eye}"/>
                </Button>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
