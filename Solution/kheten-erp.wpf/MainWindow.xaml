<Window x:Class="kheten_erp.wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:kheten_erp.wpf"
        mc:Ignorable="d"
        Title="Kheten ERP" Height="820" Width="1320"
        WindowStartupLocation="CenterScreen"
        MinHeight="640" MinWidth="1080"
        Background="{DynamicResource AppBg}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===================== SOL MENÜ ===================== -->
        <Border Grid.Column="0" Background="{DynamicResource Sidebar}"
                BorderBrush="{DynamicResource SidebarBorder}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="22,26,0,22">
                    <Border Width="34" Height="34" CornerRadius="9" Background="{DynamicResource Primary}">
                        <TextBlock Text="K" FontSize="19" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Kheten ERP" FontSize="15.5" FontWeight="Bold"
                                   Foreground="{DynamicResource Fg}"/>
                        <TextBlock Text="İşletme Yönetimi" FontSize="11" Foreground="{DynamicResource FgMuted}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Nav -->
                <StackPanel Grid.Row="1" Margin="0,4,0,0">
                    <TextBlock Text="MENÜ" Style="{StaticResource Caption}" Margin="22,4,0,8"/>
                    <RadioButton x:Name="NavDashboard"  Style="{StaticResource NavItem}" GroupName="Nav"
                                 Content="Genel Bakış"   Tag="{StaticResource Icon.Dashboard}"  IsChecked="True"
                                 Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavInventory"  Style="{StaticResource NavItem}" GroupName="Nav"
                                 Content="Stok / Envanter" Tag="{StaticResource Icon.Inventory}"
                                 Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavSales"      Style="{StaticResource NavItem}" GroupName="Nav"
                                 Content="Satış"         Tag="{StaticResource Icon.Sales}"
                                 Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavPurchasing" Style="{StaticResource NavItem}" GroupName="Nav"
                                 Content="Satınalma"     Tag="{StaticResource Icon.Purchasing}"
                                 Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavContacts"   Style="{StaticResource NavItem}" GroupName="Nav"
                                 Content="Cari Hesaplar" Tag="{StaticResource Icon.Contacts}"
                                 Checked="Nav_Checked"/>

                    <TextBlock Text="SİSTEM" Style="{StaticResource Caption}" Margin="22,18,0,8"/>
                    <RadioButton x:Name="NavSettings"   Style="{StaticResource NavItem}" GroupName="Nav"
                                 Content="Ayarlar"       Tag="{StaticResource Icon.Settings}"
                                 Checked="Nav_Checked"/>
                </StackPanel>

                <!-- Kullanıcı kartı -->
                <Border Grid.Row="2" Margin="12,12" Padding="10" CornerRadius="10"
                        Background="{DynamicResource SurfaceAlt}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource Primary}">
                            <TextBlock Text="BE" FontSize="13" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Burak Erkemen" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Fg}"/>
                            <TextBlock Text="Yönetici" FontSize="11" Foreground="{DynamicResource FgMuted}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ===================== ANA ALAN ===================== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Üst Bar -->
            <Border Grid.Row="0" Height="68" Background="{DynamicResource Topbar}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Arama -->
                    <Border Grid.Column="0" Width="380" HorizontalAlignment="Left" Height="40"
                            CornerRadius="8" Background="{DynamicResource SurfaceAlt}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="17" Height="17" Margin="12,0,0,0" Stretch="Uniform"
                                  VerticalAlignment="Center" Fill="{DynamicResource FgMuted}"
                                  Data="{StaticResource Icon.Search}"/>
                            <TextBox Grid.Column="1" VerticalContentAlignment="Center" Margin="8,0,10,0"
                                     BorderThickness="0" Background="Transparent"
                                     Foreground="{DynamicResource Fg}" CaretBrush="{DynamicResource Fg}"
                                     FontSize="13" Text="Müşteri, ürün veya belge ara..."/>
                        </Grid>
                    </Border>

                    <!-- Sağ aksiyonlar -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="ThemeToggle" Style="{StaticResource IconButton}" Click="ThemeToggle_Click"
                                ToolTip="Tema değiştir">
                            <Path x:Name="ThemeIcon" Width="19" Height="19" Stretch="Uniform"
                                  Fill="{DynamicResource FgMuted}" Data="{StaticResource Icon.Moon}"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" ToolTip="Bildirimler" Margin="4,0,0,0">
                            <Grid>
                                <Path Width="19" Height="19" Stretch="Uniform"
                                      Fill="{DynamicResource FgMuted}" Data="{StaticResource Icon.Bell}"/>
                                <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource Danger}"
                                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0"/>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource PrimaryButton}" Margin="14,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="15" Height="15" Stretch="Uniform" Fill="White"
                                      Data="{StaticResource Icon.Add}" VerticalAlignment="Center"/>
                                <TextBlock Text="Yeni Kayıt" Margin="7,0,0,0" VerticalAlignment="Center"
                                           Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- İçerik (modüller buraya yüklenir) -->
            <ContentControl x:Name="MainContent" Grid.Row="1"/>
        </Grid>
    </Grid>
</Window>
